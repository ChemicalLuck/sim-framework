{
  "name": "@chemicalluck/engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Game-agnostic life-sim engine, content editor, and Vite build plugins. Shipped as source.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChemicalLuck/sim-framework.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/ChemicalLuck/sim-framework/wiki",
  "bugs": "https://github.com/ChemicalLuck/sim-framework/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./src/engine/index.tsx",
    "./game-plugin": {
      "types": "./dist/game-plugin.d.ts",
      "default": "./dist/game-plugin.js"
    },
    "./editor/editor-plugin": {
      "types": "./dist/editor/editor-plugin.d.ts",
      "default": "./dist/editor/editor-plugin.js"
    },
    "./editor/index.html": "./src/engine/editor/index.html",
    "./vite-env": "./src/engine/vite-env.d.ts",
    "./package.json": "./package.json",
    "./*": "./src/engine/*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "vite": "^7"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@lezer/highlight": "^1.2.3",
    "@piotr-cz/redux-persist-idb-storage": "^1.1.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.10.1",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.552.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react-hook-form": "^7.75.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.15.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-undo": "^1.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@chemicalluck/config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "jsdom": "^29.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.6"
  }
}
